<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_subtitle"
        android:textColor="@color/text_tertiary"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <!-- Hardware status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/statusIr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_ir"
            android:textColor="@color/module_ir"
            android:textSize="12sp"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/statusMic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_mic"
            android:textColor="@color/module_acoustic"
            android:textSize="12sp"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/statusRf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_rf"
            android:textColor="@color/module_rf"
            android:textSize="12sp"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/statusEm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_em"
            android:textColor="@color/module_em"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Scan button -->
    <Button
        android:id="@+id/btnScan"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/action_scan"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/accent_primary"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnImportClipboard"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/action_import_clipboard"
        android:textSize="11sp"
        android:backgroundTint="@color/bg_card_elevated"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="20dp" />

    <!-- Resumable brute-force banner — visibility toggled at runtime -->
    <LinearLayout
        android:id="@+id/resumeBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card_elevated"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/resumeBannerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_warning"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnResumeBruteForce"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/action_resume"
                android:backgroundTint="@color/accent_secondary"
                android:textColor="@color/bg_primary"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnDismissResume"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/action_dismiss"
                android:backgroundTint="@color/bg_card"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Macros section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_macros"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

        <Button
            android:id="@+id/btnNewMacro"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minHeight="40dp"
            android:text="@string/action_new_macro"
            android:textSize="11sp"
            android:backgroundTint="@color/bg_card_elevated"
            android:textColor="@color/accent_secondary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minWidth="0dp" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/macroScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:id="@+id/macroChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <TextView
        android:id="@+id/macroRunning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/accent_secondary"
        android:textSize="12sp"
        android:visibility="gone"
        android:layout_marginBottom="12dp" />

    <!-- Saved devices label -->
    <TextView
        android:id="@+id/labelSaved"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_saved_devices"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="12dp" />

    <!-- Device list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/deviceList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/empty_devices"
        android:textColor="@color/text_tertiary"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:visibility="visible" />

</LinearLayout>
