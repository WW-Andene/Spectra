<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <TextView
        android:id="@+id/macroEditTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/macro_new_title"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputMacroName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_macro_name"
            android:maxLength="48"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_steps"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_card"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/stepList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <Button
        android:id="@+id/btnAddStep"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/action_add_step"
        android:backgroundTint="@color/accent_secondary"
        android:textColor="@color/bg_primary"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btnCancelMacro"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/action_cancel"
            android:backgroundTint="@color/bg_card_elevated"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnSaveMacro"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/action_save"
            android:backgroundTint="@color/accent_primary"
            android:layout_marginStart="4dp" />
    </LinearLayout>

</LinearLayout>
