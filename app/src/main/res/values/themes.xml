<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Splash theme: shown briefly during cold start until the activity
         inflates its real Theme.Spectra. Same dark background + accent
         colour for the icon so there's no white flash on launch. -->
    <style name="Theme.Spectra.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Spectra</item>
    </style>

    <style name="Theme.Spectra" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <!-- Spectra is intentionally dark-only. forceDarkAllowed=false stops
             Android 10+ system force-dark from inverting colours when the
             user enables the system-level "force dark" override on a theme
             we already designed dark. -->
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <!-- Remote button base -->
    <style name="RemoteButton">
        <item name="android:background">@color/btn_remote_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:minWidth">56dp</item>
    </style>

    <style name="RemoteButton.Power">
        <item name="android:background">@color/btn_power</item>
        <item name="android:textColor">#FFFFFFFF</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RemoteButton.DPad">
        <item name="android:background">@color/btn_dpad_bg</item>
        <item name="android:textSize">20sp</item>
    </style>

    <!-- Scan log text -->
    <style name="LogText">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <!-- ModuleBadge style removed in cycle 6 — never referenced by any
         layout. Re-add if a module-state pill is ever added to the UI. -->

</resources>
