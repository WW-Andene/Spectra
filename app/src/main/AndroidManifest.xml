<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Module 1: IR Camera Capture -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.front" android:required="false" />

    <!-- Module 2: Acoustic Fingerprint -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Module 3: RF Fingerprint -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />
    <uses-permission android:name="android.permission.NFC" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />
    <uses-feature android:name="android.hardware.nfc" android:required="false" />

    <!-- Module 4: EM Fingerprint (magnetometer — no permission needed, just hardware) -->
    <uses-feature android:name="android.hardware.sensor.compass" android:required="false" />

    <!-- Module 5 & 6: IR Blaster -->
    <uses-permission android:name="android.permission.TRANSMIT_IR" />
    <uses-feature android:name="android.hardware.consumerir" android:required="false" />

    <!-- ScanService: foreground service for the passive-scan lifecycle.
         FOREGROUND_SERVICE is the API-28+ baseline; CONNECTED_DEVICE is the
         API-34+ specific subtype required when a foreground service touches
         BLE / WiFi scanning, which our orchestrator does. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".SpectraApp"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="Spectra"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Spectra">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Spectra.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep links — three authorities under spectra://
                 - device/<id>: open the Remote screen for that device
                   (share-and-resume from chat / mail)
                 - macro/<id>: run a macro without changing UI state
                   (NFC tag triggers, B-007)
                 - command/<deviceId>/<commandName>: fire one IR command
                   stateless (NFC pinned to a single gesture, B-007) -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="spectra" android:host="device" />
                <data android:scheme="spectra" android:host="macro" />
                <data android:scheme="spectra" android:host="command" />
            </intent-filter>

            <!-- NFC NDEF dispatch (B-007). When the phone is tapped on a
                 tag containing one of our spectra:// URIs, the system
                 fires NDEF_DISCOVERED here. Without the explicit NDEF
                 filter Android falls through to the generic VIEW filter
                 above which still works, but registering NDEF gives us
                 priority over apps that registered a broader URI scope. -->
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="spectra" />
            </intent-filter>
        </activity>

        <service
            android:name=".services.ScanService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- Home-screen widget (B-002): a 1×1 tile that fires POWER on
             the primary saved device. AppWidgetProvider receives
             onUpdate; WidgetCommandReceiver receives the per-tap fire
             intent and re-hydrates the device into IrControl before
             transmitting (covers cold-process taps). -->
        <receiver
            android:name=".widget.SpectraQuickWidget"
            android:label="@string/widget_label"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_quick" />
        </receiver>

        <receiver
            android:name=".widget.WidgetCommandReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.andene.spectra.widget.action.FIRE_COMMAND" />
            </intent-filter>
        </receiver>

        <!-- Scheduled fire receiver (B-005): receives AlarmManager-fired
             intents that run a macro or one-off command at a future
             time. Not exported — only the AlarmManager owns the
             PendingIntent that targets it. -->
        <receiver
            android:name=".scheduling.ScheduledFireReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.andene.spectra.scheduling.action.FIRE_SCHEDULED" />
            </intent-filter>
        </receiver>

        <!-- Quick Settings tile (B-003): tap from the notification shade
             (or lock screen) to fire POWER on the primary device. The
             BIND_QUICK_SETTINGS_TILE permission is mandatory and must
             match android:exported="true" — TileService is invoked by
             the system, so it has to be reachable. -->
        <service
            android:name=".widget.SpectraQuickTile"
            android:label="@string/qs_tile_label"
            android:icon="@drawable/ic_qs_power"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="false" />
        </service>

    </application>

</manifest>
