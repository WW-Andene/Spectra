# Spectra release signing config.
#
# COPY this file to `keystore.properties` (which is gitignored) and fill
# in the four values below. The Gradle build picks it up automatically;
# without it, `:app:assembleRelease` falls back to debug signing.
#
# To generate a fresh release keystore, run:
#
#   keytool -genkeypair -v \
#     -keystore spectra-release.jks \
#     -alias spectra \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Then move spectra-release.jks somewhere outside this repo, set
# storeFile below to the absolute path, and fill in the rest.
#
# CI: set these as four secrets (KEYSTORE_PATH, KEYSTORE_PASSWORD,
# KEY_ALIAS, KEY_PASSWORD) and write keystore.properties from them in
# the workflow before assembleRelease.

storeFile=/absolute/path/to/spectra-release.jks
storePassword=CHANGE_ME
keyAlias=spectra
keyPassword=CHANGE_ME
